# Which LLM backend to use: anthropic | openai | local
LLM_PROVIDER=anthropic

# --- anthropic (default) ---
# API key used to generate/refine OpenSCAD code from chat prompts
ANTHROPIC_API_KEY=sk-ant-...
# Model used for chat/code generation
CHAT_MODEL=claude-sonnet-5

# --- openai ---
# Only needed when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- local (Hugging Face, via transformers.js, runs in-process on the server) ---
# Only used when LLM_PROVIDER=local. No API key needed — the model is downloaded
# once from the Hugging Face Hub and cached locally. No vision support, so
# POST /api/critique returns a 501 under this provider.
LOCAL_MODEL=onnx-community/Qwen2.5-Coder-0.5B-Instruct
LOCAL_MODEL_DTYPE=q4
LOCAL_MAX_NEW_TOKENS=2048

# Port the Express server listens on
PORT=3001

# Path to the openscad binary (must be on PATH by default)
OPENSCAD_BIN=openscad

# Max time (ms) allowed for a single "draft" quality render (used on every
# chat turn, for the live viewer) before it's killed
RENDER_TIMEOUT_MS=20000

# Max time (ms) allowed for a "final" quality render (on-demand, e.g. before
# a download) — can be much longer since draft renders keep the interactive
# loop fast and this is rarely exercised
RENDER_TIMEOUT_MS_FINAL=90000

# $fn forced via CLI override for draft-quality renders — low enough to keep
# even complex multi-object scenes fast (measured: ~2s vs 2min+ at full detail)
DRAFT_FN=8

# How many scene parts (see the system prompt's SCENE PARTS convention) to
# render in parallel at once
SCENE_PART_CONCURRENCY=4
